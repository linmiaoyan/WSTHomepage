# WSTHomepage deployment example
# Copy to .env and edit values for your environment.

# ---- Runtime mode ----
# Production: bind internal services to 127.0.0.1 by default, force DEBUG off,
# reduce noisy scanner logs, and run Flask apps with waitress.
PRODUCTION=1

# Development example:
# PRODUCTION=0
# HOST=0.0.0.0
# DEBUG=1

# ---- Main portal ----
HOST=127.0.0.1
PORT=8000
DEBUG=0
FLASK_SECRET_KEY=change-me-long-random-string

# Start main portal + QuickVote + TeacherDataSystem together.
START_STACK=1
SINGLE_PORT=1

# ---- Internal child services (START_STACK) ----
QUICKVOTE_HOST=127.0.0.1
QUICKVOTE_PORT=8001
TEACHERDATA_HOST=127.0.0.1
TEACHERDATA_PORT=8002
WAITRESS_THREADS=8

# Leave-cycle teacher requests are submitted to 智校云联 immediately by default.
# "Submitted/effective" means the application was created in 智校云联, not approved.
QUEUE_AUTO_APPROVE_LEAVE=1

# Public URLs should point at nginx, not direct 8001/8002 ports.
QUICKVOTE_PUBLIC_URL=https://example.com/quickvote/
TEACHERDATA_PUBLIC_URL=https://example.com/teacher-data/
PORTAL_HOME_URL=https://example.com/home.html

# ---- Admin gates ----
# Prefer ADMIN_MASTER_CODE + management groups in production.
ADMIN_MASTER_CODE=change-me-master-code
# Legacy single-code mode if ADMIN_MASTER_CODE is unset:
# ADMIN_GATE_CODE=change-me-admin-code

# TeacherDataSystem admin password (required by that subsystem).
ADMIN_PASSWORD=change-me-teacherdata-admin-password

# ---- External platform credentials ----
# Fill these only on the deployed server. Never commit real secrets.
EDU_CFG_PHP=
LEAVE_BASE=
LEAVE_USER=
LEAVE_PASS=
CAMPUS_BASE=
CAMPUS_TOKEN=
